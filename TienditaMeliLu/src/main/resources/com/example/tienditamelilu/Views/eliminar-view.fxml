<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.tienditamelilu.Controllers.EliminarController"
            prefHeight="400.0" prefWidth="600.0">

    <Label text="ID"/>
    <TextField fx:id="txtId"/>
    <Label text="Nombre"/>
    <TextField fx:id="txtNombre"/>
    <Label text="Stock"/>

    <HBox>
        <Button text="Eliminar" onAction="#Cerrar"></Button>
        <Button text="Agregar" onAction="#Agregar"></Button>
    </HBox>

</VBox>
